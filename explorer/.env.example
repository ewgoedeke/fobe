# FOBE Explorer — Environment Variables
# Copy to .env and fill in values.

# ── Data source ──────────────────────────────────────────────
# "files" = local filesystem (default), "supabase" = Supabase backend
FOBE_DATA_SOURCE=files

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ── Cloudflare R2 (PDF + Docling storage) ────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=4d91c98cd766fafa9943c72a61d60037
R2_BUCKET=fobe
